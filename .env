# Product Configurator Environment Configuration
# Copy this file to .env and modify as needed

# Canonical NIM runtime settings
# Get API key from: https://build.nvidia.com/
PRODCONFIG_NIM__API_KEY=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
PRODCONFIG_NIM__PROFILE=local
PRODCONFIG_NIM__AUTH_MODE=none
PRODCONFIG_NIM__PORT=19002
PRODCONFIG_NIM__MODEL=meta/llama-3.1-70b-instruct
PRODCONFIG_NIM__REPOSITORY=nim/meta/llama-3.1-70b-instruct
PRODCONFIG_NIM__TAG=latest

# Default product type
# Options: shoe, shoe_packaging, beauty_packaging, generic
PRODCONFIG_PRODUCT_TYPE=generic

# Output directory
PRODCONFIG_OUTPUT_PATH=./output

# Temporary directory
PRODCONFIG_TEMP_PATH=./temp

# Verbose logging
PRODCONFIG_VERBOSE=true

# Segmentation settings
# PRODCONFIG_SEGMENTATION__TARGET_NUM_SEGMENTS=8
# PRODCONFIG_SEGMENTATION__METHOD=hybrid

# Mesh repair settings
PRODCONFIG_MESH_REPAIR__FIX_NON_MANIFOLD=true
PRODCONFIG_MESH_REPAIR__FILL_HOLES=true
PRODCONFIG_MESH_REPAIR__SMOOTH_SURFACE=true
PRODCONFIG_MESH_REPAIR__SMOOTH_ITERATIONS=1
PRODCONFIG_MESH_REPAIR__SKIP_IF_CLEAN=false
PRODCONFIG_MESH_REPAIR__MODE=conservative

# MDL Pack settings
PRODCONFIG_MDL_PACK__TEXTURE_RESOLUTION=2048
PRODCONFIG_MDL_PACK__INCLUDE_PBR_MAPS=true
PRODCONFIG_MDL_ROOTS="/home/cec-nvidia/NVIDIA_AI-Zone_ProdDesign/mdl/vMaterials_2"

# Material RAG settings
PRODCONFIG_RAG__MATERIAL_ROOTS=["C:/Users/VY538FP/OneDrive - EY/Documents/mdl/vMaterials_2", "/home/cec-nvidia/NVIDIA_AI-Zone_ProdDesign/mdl/vMaterials_2"]
PRODCONFIG_RAG__TOP_K=3
PRODCONFIG_RAG__CANDIDATE_POOL_SIZE=20
PRODCONFIG_RAG__SIMILARITY_THRESHOLD=0.0
PRODCONFIG_RAG__ROUGHNESS_TOLERANCE=0.2
PRODCONFIG_RAG__METALLIC_TOLERANCE=0.2
PRODCONFIG_RAG__OPACITY_TOLERANCE=0.2
PRODCONFIG_RAG__ALLOWLIST_STRICT=true
PRODCONFIG_RAG__NIM_RERANK_ENABLED=true
